<Window x:Class="Ch34xProgrammer.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:Ch34xProgrammer"
    xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
    xmlns:sys="clr-namespace:System;assembly=mscorlib" Title="Multi Flash" Height="620" Width="960"
    MinHeight="620" MinWidth="960" FontFamily="Segoe UI" FontSize="13"
    Background="{DynamicResource AppBackgroundBrush}" Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinWidth" Value="30" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background"
                                    Value="{DynamicResource SelectionBackgroundBrush}" />
                                <Setter Property="Foreground"
                                    Value="{DynamicResource SelectionForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Margin" Value="2" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="MinWidth" Value="52" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBorder" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                RecognizesAccessKey="True"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background"
                                    Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background"
                                    Value="{DynamicResource HoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBackgroundBrush}" />
            <Setter Property="AlternatingRowBackground"
                Value="{DynamicResource AlternateRowBackgroundBrush}" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LightGridLineBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource LightGridLineBrush}" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SubtleBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LightGridLineBrush}" />
            <Setter Property="Padding" Value="6,3" />
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource LightGridLineBrush}" />
            <Setter Property="Padding" Value="6,1" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26" />
            <Setter Property="Margin" Value="0,3,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Focusable="False"
                                IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="18" />
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0" Margin="6,0,2,0"
                                        VerticalAlignment="Center" HorizontalAlignment="Left"
                                        Content="{TemplateBinding SelectionBoxItem}"
                                        ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                        TextElement.Foreground="{TemplateBinding Foreground}" />
                                    <Path Grid.Column="1" Width="7" Height="4"
                                        HorizontalAlignment="Center" VerticalAlignment="Center"
                                        Fill="{TemplateBinding Foreground}"
                                        Data="M 0 0 L 7 0 L 3.5 4 Z" />
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup" AllowsTransparency="True" Focusable="False"
                                IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom"
                                PopupAnimation="Slide">
                                <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer CanContentScroll="True"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DropDownToggle" Property="Opacity" Value="0.65" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="Padding" Value="6,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder" Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{DynamicResource SelectionBackgroundBrush}" />
                                <Setter Property="Foreground"
                                    Value="{DynamicResource SelectionForegroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background"
                                    Value="{DynamicResource SelectionBackgroundBrush}" />
                                <Setter Property="Foreground"
                                    Value="{DynamicResource SelectionForegroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}" />
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}" />
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="0,3,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="Menu">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="Padding" Value="8,3" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1,1,1,0"
                            Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"
                                VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background"
                                    Value="{DynamicResource SurfaceBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground"
                                    Value="{DynamicResource MutedTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="StatusBar">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        </Style>
        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}" />
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem x:Name="FileMenu" Header="_File">
                <MenuItem x:Name="NewMenuItem" Header="New" Click="FillFF_Click" />
                <Separator />
                <MenuItem x:Name="OpenMenuItem" Header="Open" Click="LoadFile_Click" />
                <MenuItem x:Name="SaveMenuItem" Header="Save" Click="SaveFile_Click" />
                <Separator />
                <MenuItem x:Name="ExitMenuItem" Header="Exit" Click="Exit_Click" />
            </MenuItem>
            <MenuItem x:Name="IcMenu" Header="_IC">
                <MenuItem x:Name="SearchIcMenuItem" Header="Search" Click="SearchIc_Click" />
                <MenuItem x:Name="ReadIdMenuItem" Header="Detect" Click="ReadId_Click" />
                <Separator />
                <MenuItem x:Name="ReadChipMenuItem" Header="Read" Click="ReadChip_Click" />
                <MenuItem x:Name="WriteChipMenuItem" Header="Write" Click="WriteChip_Click" />
                <MenuItem x:Name="VerifyChipMenuItem" Header="Verify" Click="Verify_Click" />
                <MenuItem x:Name="EraseChipMenuItem" Header="Erase" Click="Erase_Click" />
            </MenuItem>
            <MenuItem x:Name="ScriptsMenu" Header="_Scripts">
                <MenuItem x:Name="ReadVerifyScriptMenuItem" Header="Read + Verify"
                    Tag="Read + verify" Click="RunScript_Click" />
                <MenuItem x:Name="EraseWriteVerifyScriptMenuItem" Header="Erase + Write + Verify"
                    Tag="Erase + write + verify" Click="RunScript_Click" />
            </MenuItem>
            <MenuItem x:Name="HelpMenu" Header="_Help">
                <MenuItem x:Name="AboutMenuItem" Header="About" Click="About_Click" />
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackgroundBrush}">
            <ToolBar Height="36" Background="{DynamicResource ToolbarBackgroundBrush}"
                Foreground="{DynamicResource TextBrush}" ToolBarTray.IsLocked="True">
                <ToolBar.Resources>
                    <Style x:Key="{x:Static ToolBar.ButtonStyleKey}" TargetType="Button"
                        BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Margin" Value="5,2" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Width" Value="34" />
                        <Setter Property="Height" Value="28" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Background"
                            Value="{DynamicResource ToolbarButtonBackgroundBrush}" />
                        <Setter Property="BorderBrush"
                            Value="{DynamicResource ToolbarButtonBorderBrush}" />
                    </Style>
                    <Style x:Key="{x:Static ToolBar.ToggleButtonStyleKey}" TargetType="ToggleButton"
                        BasedOn="{StaticResource {x:Type ToggleButton}}">
                        <Setter Property="Margin" Value="5,2" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Width" Value="34" />
                        <Setter Property="Height" Value="28" />
                        <Setter Property="FontWeight" Value="SemiBold" />
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                        <Setter Property="Background"
                            Value="{DynamicResource ToolbarButtonBackgroundBrush}" />
                        <Setter Property="BorderBrush"
                            Value="{DynamicResource ToolbarButtonBorderBrush}" />
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Margin" Value="8,0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Separator}">
                                    <Border Width="1" Height="26"
                                        Background="{DynamicResource BorderBrush}" />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                    <Style TargetType="Path">
                        <Setter Property="Fill" Value="Transparent" />
                        <Setter Property="Stroke" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType={x:Type primitives:ButtonBase}}}" />
                        <Setter Property="StrokeThickness" Value="2" />
                        <Setter Property="StrokeStartLineCap" Value="Round" />
                        <Setter Property="StrokeEndLineCap" Value="Round" />
                        <Setter Property="StrokeLineJoin" Value="Round" />
                    </Style>
                </ToolBar.Resources>
                <ToolBar.Template>
                    <ControlTemplate TargetType="{x:Type ToolBar}">
                        <Border Background="{DynamicResource ToolbarBackgroundBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                            Padding="6,0,0,0">
                            <StackPanel IsItemsHost="True" Orientation="Horizontal" />
                        </Border>
                    </ControlTemplate>
                </ToolBar.Template>
                <Button x:Name="NewButton" ToolTip="New buffer" Click="FillFF_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M14 3v4a1 1 0 0 0 1 1h4" />
                            <Path Data="M17 21H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7l5 5v11a2 2 0 0 1-2 2z" />
                            <Path Data="M12 11v6" />
                            <Path Data="M9 14h6" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="OpenButton" ToolTip="Open binary file" Click="LoadFile_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M5 19l2.6-9.2A2 2 0 0 1 9.5 8H20a1 1 0 0 1 1 1.3L18.6 18a2 2 0 0 1-1.9 1.4H5z" />
                            <Path Data="M5 19V6a2 2 0 0 1 2-2h4l2 2h4a2 2 0 0 1 2 2" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="SaveButton" ToolTip="Save binary file" Click="SaveFile_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M6 4h11l3 3v13H4V6a2 2 0 0 1 2-2z" />
                            <Path Data="M8 4v6h8V4" />
                            <Path Data="M8 20v-6h8v6" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Separator />
                <Button x:Name="SearchIcButton" ToolTip="Search IC catalog" Click="SearchIc_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M10 10m-7 0a7 7 0 1 0 14 0a7 7 0 1 0-14 0" />
                            <Path Data="M21 21l-6-6" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="ReadIdButton" ToolTip="Read chip ID and choose IC"
                    Click="ReadId_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M4 7V5a1 1 0 0 1 1-1h2" />
                            <Path Data="M17 4h2a1 1 0 0 1 1 1v2" />
                            <Path Data="M20 17v2a1 1 0 0 1-1 1h-2" />
                            <Path Data="M7 20H5a1 1 0 0 1-1-1v-2" />
                            <Path Data="M8 8h8v8H8z" />
                            <Path Data="M9 1v3" />
                            <Path Data="M15 1v3" />
                            <Path Data="M9 20v3" />
                            <Path Data="M15 20v3" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="ReadButton" ToolTip="Read chip to buffer" Click="ReadChip_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 5v14" />
                            <Path Data="M18 13l-6 6" />
                            <Path Data="M6 13l6 6" />
                            <Path Data="M5 5h14" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="WriteButton" ToolTip="Write buffer to chip" Click="WriteChip_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M12 19V5" />
                            <Path Data="M18 11l-6-6" />
                            <Path Data="M6 11l6-6" />
                            <Path Data="M5 19h14" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="VerifyButton" ToolTip="Verify chip against buffer"
                    Click="Verify_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M9 12l2 2l4-4" />
                            <Path Data="M4 4m0 2a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2z" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="EraseButton" ToolTip="Erase chip" Click="Erase_Click">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M19 20h-10.5l-4.21-4.3a1 1 0 0 1 0-1.41l10-10a1 1 0 0 1 1.41 0l5 5a1 1 0 0 1 0 1.41L11.5 20" />
                            <Path Data="M18 13.3L11.7 7" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Button x:Name="StopButton" ToolTip="Stop current operation" Click="Stop_Click"
                    Background="{DynamicResource StopBackgroundBrush}"
                    Foreground="{DynamicResource StopForegroundBrush}">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path Data="M7 7l10 10" />
                            <Path Data="M17 7L7 17" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <Separator />
                <ToggleButton x:Name="ThemeToggleButton" ToolTip="Toggle dark mode"
                    Checked="ThemeToggleButton_Toggled" Unchecked="ThemeToggleButton_Toggled">
                    <Viewbox Width="18" Height="18">
                        <Canvas Width="24" Height="24">
                            <Path x:Name="ThemeIconPath" Data="M12 3a6 6 0 0 0 9 9a9 9 0 1 1-9-9" />
                        </Canvas>
                    </Viewbox>
                </ToggleButton>
            </ToolBar>
        </ToolBarTray>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="220" />
                <RowDefinition Height="5" />
                <RowDefinition Height="220" MinHeight="120" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                Background="{DynamicResource PanelBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="8,8,8,0">
                    <GroupBox x:Name="ProgrammerGroup" Header="Programmer" Padding="6"
                        Margin="0,0,0,6">
                        <TextBlock x:Name="HardwareStatusText" Height="20"
                            FontWeight="SemiBold" Text="Programmer disconnected" Margin="0,2,0,0" />
                    </GroupBox>

                    <GroupBox x:Name="DeviceGroup" Header="IC Info" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="DeviceNameBox" Height="20" FontWeight="SemiBold" Text="" />

                            <Grid Margin="2,6,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="20" />
                                    <RowDefinition Height="20" />
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TypeLabel" Grid.Row="0" Grid.Column="0"
                                    Text="Type:" VerticalAlignment="Center" />
                                <TextBlock x:Name="DeviceTypeText" Grid.Row="0" Grid.Column="1"
                                    VerticalAlignment="Center" />
                                <TextBlock x:Name="BitSizeLabel" Grid.Row="1" Grid.Column="0"
                                    Text="BitSize:" VerticalAlignment="Center" />
                                <TextBlock x:Name="BitSizeText" Grid.Row="1" Grid.Column="1"
                                    VerticalAlignment="Center" />
                                <TextBlock x:Name="ManufacturerLabel" Grid.Row="2" Grid.Column="0"
                                    Text="Manuf:" VerticalAlignment="Center" />
                                <TextBlock x:Name="ManufacturerText" Grid.Row="2" Grid.Column="1"
                                    VerticalAlignment="Center" />
                                <TextBlock x:Name="SizeLabel" Grid.Row="3" Grid.Column="0"
                                    Text="Size:" VerticalAlignment="Center" />
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                    <TextBlock x:Name="DeviceSizeBox" Width="80" Height="20"
                                        Text="Chip size" />
                                    <TextBlock x:Name="BytesLabel" Text=" Bytes"
                                        VerticalAlignment="Center" Margin="8,0,0,0" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="OperationGroup" Header="Operation" Padding="6"
                        Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="StartAddressLabel" Text="Start address" Height="20" />
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="0x" VerticalAlignment="Center" Margin="0,0,4,7" />
                                <TextBox x:Name="StartAddressBox" Width="92" Height="20"
                                    Text="000000" />
                            </StackPanel>
                            <CheckBox x:Name="SkipBlankPagesCheckBox" Content="Skip FF pages"
                                IsChecked="True" Margin="0,4,0,4"
                                ToolTip="Skip pages that are already blank after erase" />
                            <CheckBox x:Name="UnprotectChipCheckBox" Content="Unprotect chip"
                                IsChecked="True" Margin="0,0,0,4"
                                ToolTip="Clear SPI NOR block-protect bits before write/erase" />
                            <TextBlock x:Name="BufferStatusText" Text="Buffer: 0 bytes" Height="20"
                                Margin="0,5,0,0" />
                        </StackPanel>
                    </GroupBox>

                    <ComboBox x:Name="ChipCombo" Visibility="Collapsed"
                        SelectionChanged="ChipCombo_SelectionChanged" />
                    <ComboBox x:Name="SizeCombo" Visibility="Collapsed"
                        SelectionChanged="SizeCombo_SelectionChanged" />
                    <ComboBox x:Name="PageCombo" Visibility="Collapsed" />
                    <ComboBox x:Name="CommandCombo" Visibility="Collapsed" />
                </StackPanel>
            </Border>

            <TabControl Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,1,1">
                <TabItem x:Name="MainMemoryTab" Header="Main Memory">
                    <Grid Background="{DynamicResource SurfaceBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Background="{DynamicResource SubtleBackgroundBrush}"
                            LastChildFill="True" Margin="0,0,0,1">
                            <TextBlock DockPanel.Dock="Left" Text="Hex Editor" FontWeight="SemiBold"
                                Margin="10,0,10,0" VerticalAlignment="Center" />
                            <Button x:Name="WindowsKeySearchButton" DockPanel.Dock="Right"
                                Width="62" Height="20" Margin="2,4,8,4" Padding="0"
                                ToolTip="Find Windows key marker" Click="WindowsKeySearch_Click">Win
                                Key</Button>
                            <Button x:Name="HexSearchNextButton" DockPanel.Dock="Right" Width="24"
                                Height="20" Margin="2,4,2,4" Padding="0" ToolTip="Find next"
                                Click="HexSearchNext_Click">›</Button>
                            <Button x:Name="HexSearchPreviousButton" DockPanel.Dock="Right"
                                Width="24" Height="20" Margin="2,4,2,4" Padding="0"
                                ToolTip="Find previous" Click="HexSearchPrevious_Click">‹</Button>
                            <Button x:Name="HexReplaceButton" DockPanel.Dock="Right" Width="64"
                                Height="20" Margin="2,4,2,4" Padding="0"
                                ToolTip="Open replace dialog" Click="HexReplace_Click">Replace</Button>
                            <Button x:Name="HexSearchAllButton" DockPanel.Dock="Right" Width="34"
                                Height="20" Margin="2,4,2,4" Padding="0"
                                ToolTip="Find all matches and log offsets"
                                Click="HexSearchAll_Click">All</Button>
                            <ComboBox x:Name="HexSearchModeCombo" DockPanel.Dock="Right" Width="82"
                                Height="24" Margin="6,4,8,4" IsTextSearchEnabled="False"
                                SelectedIndex="0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}"
                                            Foreground="{DynamicResource TextBrush}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                <sys:String>Hex</sys:String>
                                <sys:String>Text</sys:String>
                                <sys:String>Offset</sys:String>
                            </ComboBox>
                            <Button x:Name="HexSearchClearButton" DockPanel.Dock="Right" Width="24"
                                Height="20" Margin="4,4,0,4" Padding="0" Visibility="Collapsed"
                                ToolTip="Clear search" Click="HexSearchClear_Click">×</Button>
                            <TextBox x:Name="HexSearchBox" Height="20" Margin="0,4,0,4"
                                ToolTip="Hex/Text finds an offset. Offset mode opens that page for editing."
                                KeyDown="HexSearchBox_KeyDown"
                                TextChanged="HexSearchBox_TextChanged" Text="" />
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="18" />
                            </Grid.ColumnDefinitions>
                            <local:HexEditorView x:Name="HexEditor" Grid.Column="0"
                                Background="{DynamicResource SurfaceBackgroundBrush}"
                                Foreground="{DynamicResource TextBrush}"
                                ScrollChanged="HexEditor_ScrollChanged" />
                            <ScrollBar x:Name="HexScrollBar" Grid.Column="1" Orientation="Vertical"
                                Minimum="0" ValueChanged="HexScrollBar_ValueChanged" />
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="1" Grid.Column="1" Height="5" HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch" Background="{DynamicResource SplitterBrush}"
                ShowsPreview="True" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext" />

            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource SurfaceBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="SizeStatusText" Text="Size: 0" Margin="3,0,8,0" />
                        <Separator />
                        <ProgressBar x:Name="OperationProgress" Width="210" Height="14" Minimum="0"
                            Maximum="100" Background="{DynamicResource ProgressTrackBrush}"
                            Margin="8,0,4,0" />
                        <TextBlock x:Name="OperationStatusText" Text="Ready" Margin="4,0,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center"
                        HorizontalAlignment="Right" Margin="0,0,6,0">
                        <Button x:Name="SaveLogButton" Height="20" Padding="8,0"
                            Click="SaveLog_Click">Save log</Button>
                        <Button x:Name="ClearLogButton" Height="20" Padding="8,0"
                            Click="ClearLog_Click">Clear log</Button>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="1">
                    <TabItem Header="Log">
                        <TextBox x:Name="LogBox" Height="Auto" Margin="0" FontFamily="Consolas"
                            FontSize="12" VerticalScrollBarVisibility="Auto"
                            HorizontalScrollBarVisibility="Auto" IsReadOnly="True"
                            TextWrapping="NoWrap"
                            Background="{DynamicResource SurfaceBackgroundBrush}"
                            Foreground="{DynamicResource TextBrush}" />
                    </TabItem>
                    <TabItem Header="Search">
                        <DataGrid x:Name="SearchHitsGrid" AutoGenerateColumns="False"
                            CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                            HeadersVisibility="None" GridLinesVisibility="Vertical"
                            SelectionMode="Single"
                            MouseDoubleClick="SearchHitsGrid_MouseDoubleClick" FontFamily="Consolas"
                            FontSize="12" RowHeight="22" ColumnHeaderHeight="24"
                            Background="{DynamicResource SurfaceBackgroundBrush}"
                            Foreground="{DynamicResource TextBrush}"
                            BorderBrush="{DynamicResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Offset" Binding="{Binding OffsetText}"
                                    Width="90" />
                                <DataGridTextColumn Header="Excerpt (hex)"
                                    Binding="{Binding HexExcerpt}" Width="*" />
                                <DataGridTextColumn Header="Excerpt (text)"
                                    Binding="{Binding TextExcerpt}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
