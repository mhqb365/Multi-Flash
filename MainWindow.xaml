<Window x:Class="Ch34xProgrammer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Ch34xProgrammer"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Multi Flash" Height="620" Width="960"
        MinHeight="620" MinWidth="960"
        FontFamily="Segoe UI" FontSize="13"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}">
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="MinWidth" Value="30"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ButtonBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              RecognizesAccessKey="True"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ToggleBorder" Property="Background" Value="{DynamicResource HoverBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBorder" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="RowBackground" Value="{DynamicResource SurfaceBackgroundBrush}"/>
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AlternateRowBackgroundBrush}"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource LightGridLineBrush}"/>
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource LightGridLineBrush}"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{DynamicResource SubtleBackgroundBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LightGridLineBrush}"/>
            <Setter Property="Padding" Value="6,3"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource LightGridLineBrush}"/>
            <Setter Property="Padding" Value="6,1"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="26"/>
            <Setter Property="Margin" Value="0,3,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Padding="0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="18"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Margin="6,0,2,0"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Left"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <Path Grid.Column="1"
                                          Width="7"
                                          Height="4"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          Fill="{TemplateBinding Foreground}"
                                          Data="M 0 0 L 7 0 L 3.5 4 Z"/>
                                </Grid>
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Slide">
                                <Border Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer CanContentScroll="True"
                                                  MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="DropDownToggle" Property="Opacity" Value="0.65"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="Padding" Value="6,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBoxItem}">
                        <Border x:Name="ItemBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter
                                HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Foreground" Value="{DynamicResource SelectionForegroundBrush}"/>
                    <Setter Property="Background" Value="{DynamicResource SelectionBackgroundBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="20"/>
            <Setter Property="Margin" Value="0,3,0,8"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource InputBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
        </Style>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="GroupBox">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="Menu">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        </Style>
        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
        </Style>
        <Style TargetType="TabControl">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource PanelBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="Padding" Value="8,3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Border x:Name="TabBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1,1,1,0"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              RecognizesAccessKey="True"
                                              VerticalAlignment="Center"
                                              HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="Background" Value="{DynamicResource SurfaceBackgroundBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="{DynamicResource MutedTextBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="StatusBar">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        </Style>
        <Style TargetType="StatusBarItem">
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="Background" Value="{DynamicResource AppBackgroundBrush}"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem x:Name="FileMenu" Header="_File">
                <MenuItem x:Name="NewMenuItem" Header="New" Click="FillFF_Click"/>
                <Separator/>
                <MenuItem x:Name="OpenMenuItem" Header="Open" Click="LoadFile_Click"/>
                <MenuItem x:Name="SaveMenuItem" Header="Save" Click="SaveFile_Click"/>
                <Separator/>
                <MenuItem x:Name="ExitMenuItem" Header="Exit" Click="Exit_Click"/>
            </MenuItem>
            <MenuItem x:Name="IcMenu" Header="_IC">
                <MenuItem x:Name="SearchIcMenuItem" Header="Search" Click="SearchIc_Click"/>
                <MenuItem x:Name="ReadIdMenuItem" Header="Detect" Click="ReadId_Click"/>
                <Separator/>
                <MenuItem x:Name="ReadChipMenuItem" Header="Read" Click="ReadChip_Click"/>
                <MenuItem x:Name="WriteChipMenuItem" Header="Write" Click="WriteChip_Click"/>
                <MenuItem x:Name="VerifyChipMenuItem" Header="Verify" Click="Verify_Click"/>
                <MenuItem x:Name="EraseChipMenuItem" Header="Erase" Click="Erase_Click"/>
            </MenuItem>
            <MenuItem x:Name="ScriptsMenu" Header="_Scripts">
                <MenuItem x:Name="ReadVerifyScriptMenuItem" Header="Read + Verify" Tag="Read + verify" Click="RunScript_Click"/>
                <MenuItem x:Name="EraseWriteVerifyScriptMenuItem" Header="Erase + Write + Verify" Tag="Erase + write + verify" Click="RunScript_Click"/>
            </MenuItem>
            <MenuItem x:Name="HelpMenu" Header="_Help">
                <MenuItem x:Name="AboutMenuItem" Header="About" Click="About_Click"/>
            </MenuItem>
        </Menu>

        <ToolBarTray DockPanel.Dock="Top" Background="{DynamicResource ToolbarBackgroundBrush}">
            <ToolBar Height="36"
                     Background="{DynamicResource ToolbarBackgroundBrush}"
                     Foreground="{DynamicResource TextBrush}"
                     ToolBarTray.IsLocked="True">
                <ToolBar.Resources>
                    <Style x:Key="{x:Static ToolBar.ButtonStyleKey}" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                        <Setter Property="Margin" Value="6,2"/>
                        <Setter Property="Padding" Value="8,3"/>
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}"/>
                    </Style>
                    <Style x:Key="{x:Static ToolBar.ToggleButtonStyleKey}" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
                        <Setter Property="Margin" Value="6,2"/>
                        <Setter Property="Padding" Value="8,3"/>
                        <Setter Property="Height" Value="28"/>
                        <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
                        <Setter Property="Background" Value="{DynamicResource ToolbarButtonBackgroundBrush}"/>
                        <Setter Property="BorderBrush" Value="{DynamicResource ToolbarButtonBorderBrush}"/>
                    </Style>
                    <Style TargetType="Separator">
                        <Setter Property="Margin" Value="8,0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Separator}">
                                    <Border Width="1"
                                            Height="26"
                                            Background="{DynamicResource BorderBrush}"/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ToolBar.Resources>
                <ToolBar.Template>
                    <ControlTemplate TargetType="{x:Type ToolBar}">
                        <Border Background="{DynamicResource ToolbarBackgroundBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="0,0,0,1"
                                Padding="6,0,0,0">
                            <StackPanel IsItemsHost="True" Orientation="Horizontal"/>
                        </Border>
                    </ControlTemplate>
                </ToolBar.Template>
                <Button x:Name="NewButton" ToolTip="New buffer" Click="FillFF_Click">New</Button>
                <Button x:Name="OpenButton" ToolTip="Open binary file" Click="LoadFile_Click">Open</Button>
                <Button x:Name="SaveButton" ToolTip="Save binary file" Click="SaveFile_Click">Save</Button>
                <Separator/>
                <Button x:Name="SearchIcButton" ToolTip="Search IC catalog" Click="SearchIc_Click">Search</Button>
                <Button x:Name="ReadIdButton" ToolTip="Read chip ID and choose IC" Click="ReadId_Click">Detect</Button>
                <Button x:Name="ReadButton" ToolTip="Read chip to buffer" Click="ReadChip_Click">Read</Button>
                <Button x:Name="WriteButton" ToolTip="Write buffer to chip" Click="WriteChip_Click">Write</Button>
                <Button x:Name="VerifyButton" ToolTip="Verify chip against buffer" Click="Verify_Click">Verify</Button>
                <Button x:Name="EraseButton" ToolTip="Erase chip" Click="Erase_Click">Erase</Button>
                <Button x:Name="StopButton" ToolTip="Stop current operation" Click="Stop_Click" Background="{DynamicResource StopBackgroundBrush}" Foreground="{DynamicResource StopForegroundBrush}">STOP</Button>
                <Separator/>
                <ToggleButton x:Name="ThemeToggleButton" ToolTip="Toggle dark mode" Checked="ThemeToggleButton_Toggled" Unchecked="ThemeToggleButton_Toggled">Dark</ToggleButton>
            </ToolBar>
        </ToolBarTray>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="220"/>
                <RowDefinition Height="5"/>
                <RowDefinition Height="220" MinHeight="120"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Row="0" Grid.Column="0" Grid.RowSpan="3"
                    Background="{DynamicResource PanelBackgroundBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0">
                <StackPanel Margin="8,8,8,0">
                    <GroupBox x:Name="ProgrammerGroup" Header="Programmer" Padding="6" Margin="0,0,0,6">
                        <TextBlock x:Name="HardwareStatusText"
                                   Height="20"
                                   Text="Programmer disconnected"
                                   Margin="0,2,0,2"/>
                    </GroupBox>

                    <GroupBox x:Name="DeviceGroup" Header="IC Info" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="DeviceNameBox" Height="20" Text="" />

                            <Grid Margin="2,8,2,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="72"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="20"/>
                                    <RowDefinition Height="20"/>
                                </Grid.RowDefinitions>
                                <TextBlock x:Name="TypeLabel" Grid.Row="0" Grid.Column="0" Text="Type:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="DeviceTypeText" Grid.Row="0" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BitSizeLabel" Grid.Row="1" Grid.Column="0" Text="BitSize:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="BitSizeText" Grid.Row="1" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ManufacturerLabel" Grid.Row="2" Grid.Column="0" Text="Manuf:" VerticalAlignment="Center"/>
                                <TextBlock x:Name="ManufacturerText" Grid.Row="2" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock x:Name="SizeLabel" Grid.Row="3" Grid.Column="0" Text="Size:" VerticalAlignment="Center"/>
                                <StackPanel Grid.Row="3" Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock x:Name="DeviceSizeBox" Width="80" Height="20" Text="Chip size"/>
                                    <TextBlock x:Name="BytesLabel" Text=" Bytes" VerticalAlignment="Center" Margin="8,0,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox x:Name="OperationGroup" Header="Operation" Padding="6" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock x:Name="StartAddressLabel" Text="Start address" Height="20"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="0x" VerticalAlignment="Center" Margin="0,0,4,7"/>
                                <TextBox x:Name="StartAddressBox" Width="92" Height="20" Text="000000"/>
                            </StackPanel>
                            <CheckBox x:Name="SkipBlankPagesCheckBox"
                                      Content="Skip FF pages"
                                      Margin="0,4,0,4"
                                      ToolTip="Skip pages that are already blank after erase"/>
                            <CheckBox x:Name="UnprotectChipCheckBox"
                                      Content="Unprotect chip"
                                      Margin="0,0,0,4"
                                      ToolTip="Clear SPI NOR block-protect bits before write/erase"/>
                            <TextBlock x:Name="BufferStatusText" Text="Buffer: 0 bytes" Height="20" Margin="0,5,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <ComboBox x:Name="ChipCombo" Visibility="Collapsed" SelectionChanged="ChipCombo_SelectionChanged"/>
                    <ComboBox x:Name="SizeCombo" Visibility="Collapsed" SelectionChanged="SizeCombo_SelectionChanged"/>
                    <ComboBox x:Name="PageCombo" Visibility="Collapsed"/>
                    <ComboBox x:Name="CommandCombo" Visibility="Collapsed"/>
                </StackPanel>
            </Border>

            <TabControl Grid.Row="0" Grid.Column="1" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,1,1">
                <TabItem x:Name="MainMemoryTab" Header="Main Memory">
                    <Grid Background="{DynamicResource SurfaceBackgroundBrush}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0" Background="{DynamicResource SubtleBackgroundBrush}" LastChildFill="True" Margin="0,0,0,1">
                            <TextBlock DockPanel.Dock="Left" Text="Hex Editor" FontWeight="SemiBold" Margin="10,0,10,0" VerticalAlignment="Center"/>
                            <Button x:Name="WindowsKeySearchButton"
                                    DockPanel.Dock="Right"
                                    Width="62"
                                    Height="20"
                                    Margin="2,4,8,4"
                                    Padding="0"
                                    ToolTip="Find Windows key marker"
                                    Click="WindowsKeySearch_Click">Win Key</Button>
                            <Button x:Name="HexSearchNextButton"
                                    DockPanel.Dock="Right"
                                    Width="24"
                                    Height="20"
                                    Margin="2,4,2,4"
                                    Padding="0"
                                    ToolTip="Find next"
                                    Click="HexSearchNext_Click">›</Button>
                            <Button x:Name="HexSearchPreviousButton"
                                    DockPanel.Dock="Right"
                                    Width="24"
                                    Height="20"
                                    Margin="2,4,2,4"
                                    Padding="0"
                                    ToolTip="Find previous"
                                    Click="HexSearchPrevious_Click">‹</Button>
                            <Button x:Name="HexReplaceButton"
                                    DockPanel.Dock="Right"
                                    Width="64"
                                    Height="20"
                                    Margin="2,4,2,4"
                                    Padding="0"
                                    ToolTip="Open replace dialog"
                                    Click="HexReplace_Click">Replace</Button>
                            <Button x:Name="HexSearchAllButton"
                                    DockPanel.Dock="Right"
                                    Width="34"
                                    Height="20"
                                    Margin="2,4,2,4"
                                    Padding="0"
                                    ToolTip="Find all matches and log offsets"
                                    Click="HexSearchAll_Click">All</Button>
                            <ComboBox x:Name="HexSearchModeCombo"
                                      DockPanel.Dock="Right"
                                      Width="82"
                                      Height="24"
                                      Margin="6,4,8,4"
                                      IsTextSearchEnabled="False"
                                      SelectedIndex="0">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" Foreground="{DynamicResource TextBrush}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                                <sys:String>Hex</sys:String>
                                <sys:String>Text</sys:String>
                                <sys:String>Offset</sys:String>
                            </ComboBox>
                            <Button x:Name="HexSearchClearButton"
                                    DockPanel.Dock="Right"
                                    Width="24"
                                    Height="20"
                                    Margin="4,4,0,4"
                                    Padding="0"
                                    Visibility="Collapsed"
                                    ToolTip="Clear search"
                                    Click="HexSearchClear_Click">×</Button>
                            <TextBox x:Name="HexSearchBox"
                                     Height="20"
                                     Margin="0,4,0,4"
                                     ToolTip="Hex/Text finds an offset. Offset mode opens that page for editing."
                                     KeyDown="HexSearchBox_KeyDown"
                                     TextChanged="HexSearchBox_TextChanged"
                                     Text=""/>
                        </DockPanel>

                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="18"/>
                            </Grid.ColumnDefinitions>
                            <local:HexEditorView x:Name="HexEditor"
                                                 Grid.Column="0"
                                                 Background="{DynamicResource SurfaceBackgroundBrush}"
                                                 Foreground="{DynamicResource TextBrush}"
                                                 ScrollChanged="HexEditor_ScrollChanged"/>
                            <ScrollBar x:Name="HexScrollBar"
                                       Grid.Column="1"
                                       Orientation="Vertical"
                                       Minimum="0"
                                       ValueChanged="HexScrollBar_ValueChanged"/>
                        </Grid>
                    </Grid>
                </TabItem>
            </TabControl>

            <GridSplitter Grid.Row="1" Grid.Column="1"
                          Height="5"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          Background="{DynamicResource SplitterBrush}"
                          ShowsPreview="True"
                          ResizeDirection="Rows"
                          ResizeBehavior="PreviousAndNext"/>

            <Grid Grid.Row="2" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource SurfaceBackgroundBrush}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock x:Name="SizeStatusText" Text="Size: 0" Margin="3,0,8,0"/>
                        <Separator/>
                        <ProgressBar x:Name="OperationProgress" Width="210" Height="14" Minimum="0" Maximum="100" Background="{DynamicResource ProgressTrackBrush}" Margin="8,0,4,0"/>
                        <TextBlock x:Name="OperationStatusText" Text="Ready" Margin="4,0,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,6,0">
                        <Button x:Name="SaveLogButton"
                                Height="20"
                                Padding="8,0"
                                Click="SaveLog_Click">Save log</Button>
                        <Button x:Name="ClearLogButton"
                                Height="20"
                                Padding="8,0"
                                Click="ClearLog_Click">Clear log</Button>
                    </StackPanel>
                </Grid>

                <TabControl Grid.Row="1">
                    <TabItem Header="Log">
                        <TextBox x:Name="LogBox"
                                 Height="Auto"
                                 Margin="0"
                                 FontFamily="Consolas" FontSize="12"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 IsReadOnly="True"
                                 TextWrapping="NoWrap"
                                 Background="{DynamicResource SurfaceBackgroundBrush}"
                                 Foreground="{DynamicResource TextBrush}"/>
                    </TabItem>
                    <TabItem Header="Search">
                        <DataGrid x:Name="SearchHitsGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  HeadersVisibility="None"
                                  GridLinesVisibility="Vertical"
                                  SelectionMode="Single"
                                  MouseDoubleClick="SearchHitsGrid_MouseDoubleClick"
                                  FontFamily="Consolas"
                                  FontSize="12"
                                  RowHeight="22"
                                  ColumnHeaderHeight="24"
                                  Background="{DynamicResource SurfaceBackgroundBrush}"
                                  Foreground="{DynamicResource TextBrush}"
                                  BorderBrush="{DynamicResource BorderBrush}">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Offset" Binding="{Binding OffsetText}" Width="90"/>
                                <DataGridTextColumn Header="Excerpt (hex)" Binding="{Binding HexExcerpt}" Width="*"/>
                                <DataGridTextColumn Header="Excerpt (text)" Binding="{Binding TextExcerpt}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </TabItem>
                </TabControl>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
