<Window x:Class="Ch34xProgrammer.ReplaceDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Replace" Width="420" Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI" FontSize="13">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="HintText" Grid.Row="0" Margin="0,0,0,8"/>
        <TextBox x:Name="ReplaceTextBox"
                 Grid.Row="1"
                 Height="24"
                 VerticalAlignment="Top"
                 Background="{DynamicResource InputBackgroundBrush}"
                 BorderBrush="{DynamicResource BorderBrush}"
                 Foreground="{DynamicResource TextBrush}"
                 KeyDown="ReplaceTextBox_KeyDown"/>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button x:Name="ReplaceButton" Width="76" Height="26" Margin="0,0,8,0" Click="Replace_Click">Replace</Button>
            <Button x:Name="ReplaceAllButton" Width="86" Height="26" Click="ReplaceAll_Click">Replace all</Button>
        </StackPanel>
    </Grid>
</Window>
